---
import { TRIVIA_CATEGORIES, QUIZ_LIMITS } from "../types";

const categories = TRIVIA_CATEGORIES;
const { MIN_QUESTIONS, MAX_QUESTIONS, DEFAULT_QUESTIONS } = QUIZ_LIMITS;
const base = import.meta.env.BASE_URL;
---

<div
  id="quiz-config-root"
  style="max-width: 640px; margin: 0 auto;"
>
  <div class="card" style="padding: 2.5rem;">
    <div style="margin-bottom: 2rem;">
      <p class="label" style="margin-bottom: 0.4rem;">Configure</p>
      <h2 style="font-family: var(--font-display); font-size: 2.2rem; letter-spacing: 0.04em; margin: 0;">
        SOLO QUIZ
      </h2>
    </div>

    <form id="quiz-form" style="display: flex; flex-direction: column; gap: 1.75rem;">
      <div>
        <p class="label" style="margin-bottom: 1rem;">Number of Questions</p>
        <div style="text-align: center; margin-bottom: 1rem;">
          <div style="display: inline-flex; align-items: center; justify-content: center; width: 88px; height: 88px; border-radius: 50%; border: 2px solid var(--color-gold); background: var(--color-gold-dim);">
            <span
              id="amount-display"
              style="font-family: var(--font-display); font-size: 2.5rem; color: var(--color-gold);"
            >{DEFAULT_QUESTIONS}</span>
          </div>
          <p style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-text-dim); margin-top: 0.5rem; letter-spacing: 0.08em;">QUESTIONS</p>
        </div>
        <input
          type="range"
          id="amount"
          name="amount"
          min={MIN_QUESTIONS}
          max={MAX_QUESTIONS}
          value={DEFAULT_QUESTIONS}
          class="slider"
          style="width: 100%; height: 6px; background: var(--color-border); border-radius: 99px; appearance: none; outline: none; cursor: pointer;"
        />
        <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-text-dim); margin-top: 0.5rem; letter-spacing: 0.08em;">
          <span>{MIN_QUESTIONS}</span>
          <span>{MAX_QUESTIONS}</span>
        </div>
      </div>

      <div>
        <label for="category" class="label" style="display: block; margin-bottom: 0.6rem;">Category</label>
        <select id="category" name="category" class="input-field">
          <option value="">Any Category</option>
          {categories.map((cat) => (
            <option value={cat.id}>{cat.name}</option>
          ))}
        </select>
      </div>

      <div>
        <p class="label" style="margin-bottom: 0.8rem;">Difficulty</p>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          {[
            { value: "", label: "Any" },
            { value: "easy", label: "Easy" },
            { value: "medium", label: "Medium" },
            { value: "hard", label: "Hard" },
          ].map((opt) => (
            <label class="difficulty-option" style="cursor: pointer;">
              <input
                type="radio"
                name="difficulty"
                value={opt.value}
                checked={opt.value === ""}
                style="display: none;"
              />
              <span class={`difficulty-pill ${opt.value === "" ? "difficulty-pill--active" : ""}`} data-value={opt.value}>
                {opt.label}
              </span>
            </label>
          ))}
        </div>
      </div>

      <div>
        <p class="label" style="margin-bottom: 0.8rem;">Question Type</p>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          {[
            { value: "", label: "Any" },
            { value: "multiple", label: "Multiple Choice" },
            { value: "boolean", label: "True / False" },
          ].map((opt) => (
            <label class="difficulty-option" style="cursor: pointer;">
              <input
                type="radio"
                name="type"
                value={opt.value}
                checked={opt.value === ""}
                style="display: none;"
              />
              <span class={`difficulty-pill ${opt.value === "" ? "difficulty-pill--active" : ""}`} data-value={opt.value}>
                {opt.label}
              </span>
            </label>
          ))}
        </div>
      </div>

      <button type="submit" id="start-btn" class="btn-primary" style="width: 100%; text-align: center; margin-top: 0.5rem;">
        START QUIZ
      </button>
    </form>

    <div id="error-box" style="display: none; margin-top: 1rem; padding: 1rem 1.25rem; background: var(--color-red-dim); border: 1px solid var(--color-red); border-radius: 8px;">
      <p style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-red);" id="error-msg"></p>
    </div>
  </div>
</div>

<div id="loading-overlay" style="display: none; position: fixed; inset: 0; background: rgba(7,7,17,0.85); z-index: 999; align-items: center; justify-content: center; flex-direction: column; gap: 1rem;">
  <div style="width: 48px; height: 48px; border: 3px solid var(--color-border); border-top-color: var(--color-gold); border-radius: 50%; animation: spin 0.8s linear infinite;"></div>
  <p style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-text-dim); letter-spacing: 0.1em;">LOADING QUESTIONS...</p>
</div>

<style>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .difficulty-pill {
    display: inline-block;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--color-text-dim);
    transition: all 0.15s ease;
    background: transparent;
    user-select: none;
  }

  .difficulty-pill--active {
    border-color: var(--color-gold);
    color: var(--color-gold);
    background: var(--color-gold-dim);
  }

  .difficulty-option:hover .difficulty-pill:not(.difficulty-pill--active) {
    border-color: var(--color-text-dim);
    color: var(--color-text);
  }
</style>

<script define:vars={{ base }}>
  const amountInput = document.getElementById("amount");
  const amountDisplay = document.getElementById("amount-display");
  const form = document.getElementById("quiz-form");
  const startBtn = document.getElementById("start-btn");
  const errorBox = document.getElementById("error-box");
  const errorMsg = document.getElementById("error-msg");
  const loadingOverlay = document.getElementById("loading-overlay");

  amountInput.addEventListener("input", () => {
    amountDisplay.textContent = amountInput.value;
  });

  document.querySelectorAll(".difficulty-option input[type=radio]").forEach((radio) => {
    radio.addEventListener("change", () => {
      const group = radio.closest(".difficulty-option").parentElement;
      group.querySelectorAll(".difficulty-pill").forEach((pill) => {
        pill.classList.remove("difficulty-pill--active");
      });
      radio.closest(".difficulty-option").querySelector(".difficulty-pill").classList.add("difficulty-pill--active");
    });
  });

  function decodeHtmlEntities(text) {
    const ta = document.createElement("textarea");
    ta.innerHTML = text;
    return ta.value;
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorBox.style.display = "none";
    loadingOverlay.style.display = "flex";
    startBtn.disabled = true;

    const formData = new FormData(form);
    const amount = parseInt(formData.get("amount"));
    const category = formData.get("category");
    const difficulty = formData.get("difficulty");
    const type = formData.get("type");

    try {
      const url = new URL("https://opentdb.com/api.php");
      url.searchParams.append("amount", amount.toString());
      if (category) url.searchParams.append("category", category);
      if (difficulty) url.searchParams.append("difficulty", difficulty);
      if (type) url.searchParams.append("type", type);

      const res = await fetch(url.toString());
      if (!res.ok) throw new Error(`HTTP error: ${res.status}`);
      const data = await res.json();

      const codes = { NO_RESULTS: 1, INVALID_PARAMETER: 2, TOKEN_NOT_FOUND: 3, TOKEN_EMPTY: 4 };
      if (data.response_code !== 0) {
        const messages = {
          [codes.NO_RESULTS]: "No results found. Try adjusting your search parameters.",
          [codes.INVALID_PARAMETER]: "Invalid parameter. Check your quiz configuration.",
          [codes.TOKEN_NOT_FOUND]: "Token not found. Please try again.",
          [codes.TOKEN_EMPTY]: "All possible questions exhausted.",
        };
        throw new Error(messages[data.response_code] || "Unknown API error.");
      }

      const questions = data.results.map((q) => ({
        ...q,
        question: decodeHtmlEntities(q.question),
        correct_answer: decodeHtmlEntities(q.correct_answer),
        incorrect_answers: q.incorrect_answers.map(decodeHtmlEntities),
      }));

      const config = { amount, category: category ? parseInt(category) : undefined, difficulty: difficulty || undefined, type: type || undefined };

      sessionStorage.removeItem("quizReviewData");
      sessionStorage.setItem("triviaQuestions", JSON.stringify(questions));
      sessionStorage.setItem("quizConfig", JSON.stringify(config));
      window.location.href = base + "/quiz";
    } catch (err) {
      loadingOverlay.style.display = "none";
      startBtn.disabled = false;
      errorBox.style.display = "block";
      errorMsg.textContent = err instanceof Error ? err.message : "An unexpected error occurred.";
    }
  });
</script>
